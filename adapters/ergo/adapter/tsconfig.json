{
    "compilerOptions": {
        "strict": true,
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "outDir": "dist",
        "declaration": true,
        "sourceMap": true,
        "skipLibCheck": true
    },
    "include": ["src", "../contracts/contracts.ts"],
    "exclude": ["../contracts/compile-guard.ts"]
}
