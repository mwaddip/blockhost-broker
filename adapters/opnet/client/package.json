{
    "name": "blockhost-client-opnet",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "postinstall": "patch-package",
        "build": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/main.js --target=node22 --alias:undici=./src/undici-shim.ts --alias:bip39=./src/bip39-shim.ts --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
        "start": "node dist/main.js",
        "dev": "tsx src/main.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@btc-vision/bitcoin": "^7.0.0",
        "@btc-vision/ecpair": "^4.0.5",
        "@btc-vision/transaction": "^1.8.2",
        "@noble/ciphers": "^2.1.1",
        "@noble/curves": "^2.0.1",
        "@noble/hashes": "^2.0.1",
        "@scure/bip39": "^2.0.0",
        "opnet": "^1.8.5"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "esbuild": "^0.27.3",
        "patch-package": "^8.0.1",
        "tsx": "^4.0.0",
        "typescript": "^5.9.3"
    }
}
