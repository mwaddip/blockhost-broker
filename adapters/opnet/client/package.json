{
    "name": "blockhost-client-opnet",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "build": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/main.js --target=node22 --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
        "start": "node dist/main.js",
        "dev": "tsx src/main.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@btc-vision/bitcoin": "^7.0.0-rc.5",
        "@btc-vision/ecpair": "4.0.5",
        "@btc-vision/transaction": "^1.8.0-rc.7",
        "@noble/ciphers": "^2.1.1",
        "@noble/curves": "^1.8.0",
        "@noble/hashes": "^1.7.0",
        "opnet": "^1.8.1-rc.9"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "esbuild": "^0.27.3",
        "tsx": "^4.0.0",
        "typescript": "^5.9.3"
    }
}
