[
  {
    "name": "evm",
    "match": "^0x[0-9a-fA-F]{40}$",
    "adapter": "builtin",
    "timeout": 300,
    "poll_interval": 5
  },
  {
    "name": "opnet",
    "match": "^(0x[0-9a-fA-F]{64}|opr1.+)$",
    "adapter": "npx",
    "adapter_args": ["--prefix", "/opt/blockhost/adapters/opnet/client", "tsx", "/opt/blockhost/adapters/opnet/client/src/main.ts", "request"],
    "rpc_url": "https://regtest.opnet.org",
    "registry_pubkey": "0x36cd9b40a888ba905bb3a52fb28f56ef1ffdb9c61a858a83687268e68114a2c7",
    "timeout": 2400
  }
]
